<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Modern Product Website</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; font-family: Arial, sans-serif; }
    body { line-height: 1.6; }
    header { background: #0f172a; color: white; padding: 20px 50px; display: flex; justify-content: space-between; }
    header h1 { font-size: 24px; }
    header nav a { color: white; margin-left: 20px; text-decoration: none; }

    /* Hero */
    .hero { height: 90vh; display: flex; align-items: center; justify-content: center; text-align: center; background: linear-gradient(to right, #6366f1, #06b6d4); color: white; }
    .hero h2 { font-size: 48px; margin-bottom: 20px; }
    .hero p { font-size: 18px; margin-bottom: 20px; }
    .btn { padding: 12px 25px; background: white; color: #333; border-radius: 25px; text-decoration: none; font-weight: bold; }

    /* Features */
    .features { padding: 60px 20px; text-align: center; }
    .features h2 { margin-bottom: 40px; }
    .feature-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
    .feature { padding: 20px; border-radius: 10px; background: #f1f5f9; }

    /* Testimonials */
    .testimonials { background: #e2e8f0; padding: 60px 20px; }
    .testimonial-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
    .card { background: white; padding: 20px; border-radius: 10px; }

    /* Pricing */
    .pricing { padding: 60px 20px; text-align: center; }
    .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
    .plan { border: 1px solid #ddd; padding: 20px; border-radius: 10px; }

    /* Contact */
    .contact { background: #f8fafc; padding: 60px 20px; }
    form { max-width: 500px; margin: auto; display: flex; flex-direction: column; }
    form input, form textarea { margin-bottom: 15px; padding: 10px; border-radius: 5px; border: 1px solid #ccc; }
    form button { padding: 10px; background: #6366f1; color: white; border: none; border-radius: 5px; }

    /* Footer */
    footer { background: #0f172a; color: white; text-align: center; padding: 20px; }
  </style>
</head>
<body>

<header>
  <h1>MyProduct</h1>
  <nav>
    <a href="#">Home</a>
    <a href="#features">Features</a>
    <a href="#pricing">Pricing</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<section class="hero">
  <div>
    <h2>Build Something Amazing</h2>
    <p>Your product solution for modern problems</p>
    <a href="#pricing" class="btn">Get Started</a>
  </div>
</section>

<section class="features" id="features">
  <h2>Features</h2>
  <div class="feature-grid">
    <div class="feature"><h3>Fast</h3><p>Super fast performance</p></div>
    <div class="feature"><h3>Secure</h3><p>Top-level security</p></div>
    <div class="feature"><h3>Easy</h3><p>User-friendly interface</p></div>
  </div>
</section>

<section class="testimonials">
  <h2 style="text-align:center; margin-bottom:30px;">Testimonials</h2>
  <div class="testimonial-grid">
    <div class="card"><p>"Amazing product!"</p><h4>- User A</h4></div>
    <div class="card"><p>"Highly recommend"</p><h4>- User B</h4></div>
    <div class="card"><p>"Great support"</p><h4>- User C</h4></div>
  </div>
</section>

<section class="pricing" id="pricing">
  <h2>Pricing</h2>
  <div class="pricing-grid">
    <div class="plan"><h3>Basic</h3><p>$10/month</p></div>
    <div class="plan"><h3>Pro</h3><p>$20/month</p></div>
    <div class="plan"><h3>Enterprise</h3><p>$50/month</p></div>
  </div>
</section>

<section class="contact" id="contact">
  <h2 style="text-align:center; margin-bottom:20px;">Contact Us</h2>
  <form>
    <input type="text" placeholder="alisha" required>
    <input type="email" placeholder="ali@gmail.com" required>
    <textarea rows="5" placeholder="Your Message"></textarea>
    <button type="submit">Send Message</button>
  </form>
</section>

<footer>
  <p>© 2026 MyProduct. All rights reserved.</p>
</footer>

</body>
</html>
